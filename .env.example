# ==============================================================================
# myteam-project — Environment Variables
# ==============================================================================
# Copy to .env and fill in your secrets:
#   cp .env.example .env
#
# This file is gitignored — never commit real secrets.
# ==============================================================================

# ==============================================================================
# 1. OpenClaw Gateway
# ==============================================================================
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_ROOT_PASSWORD=

# ==============================================================================
# 2. LLM API Keys (OpenRouter) — 1 key per Agent
# ==============================================================================
OPENROUTER_API_KEY_CHIEF=
OPENROUTER_API_KEY_ANALYST=
OPENROUTER_API_KEY_FOREX_EXECUTOR=
OPENROUTER_API_KEY_CRYPTO_EXECUTOR=

# ==============================================================================
# 3. LLM for Services (YouTube Research, Summarization, etc.)
# ==============================================================================
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# ==============================================================================
# 4. Discord — Bot Tokens (1 token per Agent)
# ==============================================================================
DISCORD_BOT_TOKEN_chief=
DISCORD_BOT_TOKEN_analyst=
DISCORD_BOT_TOKEN_forex_executor=
DISCORD_BOT_TOKEN_crypto_executor=

# ==============================================================================
# 5. Discord — Server & Channel IDs
# ==============================================================================
DISCORD_SERVER_ID=

# --- Channel IDs: 🌐 GENERAL ---
DISCORD_CHANNEL_OPENROUTER_SETTING=
DISCORD_CHANNEL_OPENSOURCE_GITHUB=

# --- Channel IDs: 🏢 EXECUTIVE DIRECT ---
DISCORD_CHANNEL_CEO_OFFICE=
DISCORD_CHANNEL_COMPANY_REPORTS=

# --- Channel IDs: 💻 OPERATIONS & TECH ---
DISCORD_CHANNEL_TECH_LAB=
DISCORD_CHANNEL_SYSTEM_LOGS=

# --- Channel IDs: 📈 GROWTH & MARKETING ---
DISCORD_CHANNEL_MARKETING_HUB=

# --- Channel IDs: 🤝 TEAM COLLABORATION ---
DISCORD_CHANNEL_AGENT_COWORKING=
DISCORD_CHANNEL_WAR_ROOM=

# --- Channel IDs: 📊 FINANCIAL & TRADING HUB ---
DISCORD_CHANNEL_TRADING_TERMINAL=
DISCORD_CHANNEL_ECONOMIC_CALENDAR=

# ==============================================================================
# 6. MT5 (Forex) — Markets4you / เปิดใช้งาน
# ==============================================================================
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# ==============================================================================
# 7. Binance (Crypto) — ปิดไว้ก่อน รอเปิดใช้งานทีหลัง
# ==============================================================================
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ==============================================================================
# 8. Telegram (แจ้งเตือน)
# ==============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ==============================================================================
# 9. n8n — Workflow Automation
# ==============================================================================
N8N_ENCRYPTION_KEY=
N8N_PASSWORD=
N8N_WEBHOOK_SECRET=
N8N_API_KEY=

# ==============================================================================
# 10. Google Workspace (optional — ใช้โดย Chief)
# ==============================================================================
GOOGLE_SERVICE_ACCOUNT_B64=

# ==============================================================================
# 11. Unified Trading MCP Server (รันบน Windows โดยตรง)
# ==============================================================================
TRADING_MCP_HOST=0.0.0.0
TRADING_MCP_PORT=3003

# ==============================================================================
# 12. TradingView MCP (ไม่ต้อง API key — ฟรี)
# ==============================================================================
TRADINGVIEW_MCP_URL=http://tradingview-mcp:8000

# ==============================================================================
# 13. SearXNG (ไม่ต้อง API key — self-hosted)
# ==============================================================================
SEARXNG_URL=http://searxng:8080

# ==============================================================================
# 14. Crawl4AI (ไม่ต้อง API key — self-hosted)
# ==============================================================================
CRAWL4AI_URL=http://crawl4ai:8081

# ==============================================================================
# 15. YouTube Research Service
# ==============================================================================
YOUTUBE_RESEARCH_OPENROUTER_KEY=${OPENROUTER_API_KEY}
YOUTUBE_RESEARCH_MODEL=openai/gpt-4o-mini
VAULT_PATH=./km-vault/research/youtube-summaries/
